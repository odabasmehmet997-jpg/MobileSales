<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
    <com.proje.mobilesales.core.widget.AppBarSwipeRefreshLayout
            android:id="@+id/swipe_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            <RelativeLayout android:id="@+id/content_frame"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                <LinearLayout android:orientation="horizontal"
                              android:id="@+id/lyHeader"
                              android:layout_width="match_parent"
                              android:layout_height="match_parent"
                              android:weightSum="1">
                    <TextView android:layout_gravity="center"
                              android:text="@string/str_risk_criteria"
                              android:singleLine="false"
                              android:layout_weight="0.31"
                              style="@style/textCustomerGeneralStyle"/>
                    <TextView android:layout_gravity="center"
                              android:text="@string/str_limit"
                              android:singleLine="false"
                              android:layout_weight="0.23"
                              style="@style/textCustomerGeneralStyle"/>
                    <TextView android:layout_gravity="center"
                              android:text="@string/str_closed_risk"
                              android:singleLine="false"
                              android:layout_weight="0.23"
                              style="@style/textCustomerGeneralStyle"/>
                    <TextView android:layout_gravity="center"
                              android:text="@string/str_total_quantity"
                              android:singleLine="false" android:layout_weight="0.23"
                              style="@style/textCustomerGeneralStyle"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rcw"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/lyHeader"/>
                <LinearLayout android:orientation="horizontal"
                              android:layout_width="match_parent"
                              android:layout_height="match_parent"
                              android:weightSum="1" android:layout_below="@+id/rcw">
                    <TextView android:visibility="invisible"
                              android:singleLine="false"
                              android:layout_weight="0.31"
                              style="@style/textCustomerGeneralStyle"/>
                    <TextView
                            android:id="@+id/txt_riskLimitTotal"
                              android:singleLine="false"
                              android:layout_weight="0.23"
                              style="@style/textCustomerGeneralStyle"/>
                    <TextView
                              android:id="@+id/txt_riskLimitClosedTotal"
                              android:singleLine="false"
                              android:layout_weight="0.23"
                              style="@style/textCustomerGeneralStyle"/>
                    <TextView
                              android:id="@+id/txt_riskTotal"
                              android:singleLine="false"
                              android:layout_weight="0.23"
                              style="@style/textCustomerGeneralStyle"/>
                </LinearLayout>
            </RelativeLayout>
        </androidx.core.widget.NestedScrollView>
    </com.proje.mobilesales.core.widget.AppBarSwipeRefreshLayout>
</RelativeLayout>
