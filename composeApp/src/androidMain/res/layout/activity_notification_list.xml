<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent">
    <include android:id="@+id/include" app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0"
             app:layout_constraintTop_toTopOf="0" layout="@layout/toolbar"/>
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/main_area" android:layout_width="match_parent"
                                                       android:layout_height="0dp" android:layout_margin="8dp"
                                                       app:layout_constraintBottom_toBottomOf="0"
                                                       app:layout_constraintLeft_toLeftOf="0"
                                                       app:layout_constraintRight_toRightOf="0"
                                                       app:layout_constraintTop_toBottomOf="@+id/include">
        <androidx.appcompat.widget.AppCompatEditText android:id="@+id/edtSearch" android:focusable="true"
                                                     android:focusableInTouchMode="true" android:layout_width="0dp"
                                                     android:layout_height="wrap_content" android:minHeight="48dp"
                                                     android:maxLines="1" android:inputType="text"
                                                     android:imeOptions="actionSearch"
                                                     android:contentDescription="@string/str_search"
                                                     app:layout_constraintEnd_toStartOf="@+id/imgBtnSearch"
                                                     app:layout_constraintStart_toStartOf="0"
                                                     app:layout_constraintTop_toBottomOf="@+id/btnCancel"/>
        <androidx.appcompat.widget.AppCompatImageButton android:gravity="center" android:id="@+id/imgBtnClearSearch"
                                                        android:background="@null" android:padding="12dp"
                                                        android:layout_width="48dp" android:layout_height="48dp"
                                                        android:src="@drawable/ic_baseline_search_off_24"
                                                        android:scaleType="fitCenter" android:tint="@color/grey600"
                                                        android:layout_weight="1"
                                                        android:contentDescription="@string/str_clear"
                                                        app:layout_constraintEnd_toEndOf="0"
                                                        app:layout_constraintTop_toBottomOf="@+id/btnCancel"/>
        <androidx.appcompat.widget.AppCompatImageButton android:gravity="center" android:id="@+id/imgBtnSearch"
                                                        android:background="@null" android:padding="12dp"
                                                        android:layout_width="48dp" android:layout_height="48dp"
                                                        android:src="@drawable/ic_baseline_search_24"
                                                        android:scaleType="fitCenter" android:tint="@color/grey600"
                                                        android:layout_weight="1"
                                                        android:contentDescription="@string/str_search"
                                                        app:layout_constraintEnd_toStartOf="@+id/imgBtnClearSearch"
                                                        app:layout_constraintTop_toBottomOf="@+id/btnCancel"/>
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout android:id="@+id/refresh_layout"
                                                               android:paddingBottom="@dimen/list_item_spacing_half"
                                                               android:layout_width="0dp" android:layout_height="0dp"
                                                               android:layout_marginTop="8dp"
                                                               app:layout_constraintBottom_toBottomOf="0"
                                                               app:layout_constraintEnd_toEndOf="0"
                                                               app:layout_constraintStart_toStartOf="0"
                                                               app:layout_constraintTop_toBottomOf="@+id/edtSearch">
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/list" android:clipToPadding="false"
                                                       android:layout_width="0dp" android:layout_height="0dp"
                                                       app:layout_constraintBottom_toBottomOf="0"
                                                       app:layout_constraintEnd_toEndOf="0"
                                                       app:layout_constraintStart_toStartOf="0"
                                                       app:layout_constraintTop_toBottomOf="@+id/refresh_layout"/>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        <include android:id="@+id/noResults" android:paddingBottom="@dimen/list_item_spacing_half"
                 android:layout_width="0dp" android:layout_height="0dp" android:layout_marginTop="8dp"
                 app:layout_constraintBottom_toBottomOf="0" app:layout_constraintLeft_toLeftOf="0"
                 app:layout_constraintRight_toRightOf="0" app:layout_constraintTop_toBottomOf="@+id/edtSearch"
                 layout="@layout/empty_search"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <include android:id="@+id/loadingBar" android:visibility="gone" android:layout_width="match_parent"
             android:layout_height="0dp" app:layout_constraintBottom_toBottomOf="0"
             app:layout_constraintLeft_toLeftOf="0" app:layout_constraintRight_toRightOf="0"
             app:layout_constraintTop_toBottomOf="@+id/include" layout="@layout/loading_item"/>
</androidx.constraintlayout.widget.ConstraintLayout>
