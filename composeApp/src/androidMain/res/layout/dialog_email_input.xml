<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools"
              android:orientation="vertical"
              android:id="@+id/layout_root" android:padding="10dp" android:layout_width="match_parent"
              android:layout_height="match_parent">
    <TextView android:textAppearance="?android:attr/textAppearanceMedium" android:id="@+id/txtViewTitle"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="E-Posta Adresi Giriniz :"/>
    <TextView android:textColor="@color/orange500" android:id="@+id/txtViewError" android:layout_width="wrap_content"
              android:layout_height="wrap_content" android:singleLine="false" tools:ignore="VisualLintTextFieldSize"/>
    <EditText android:id="@+id/edtDialogUserInput" android:layout_width="match_parent"
              android:layout_height="wrap_content">
        <requestFocus/>
    </EditText>
</LinearLayout>