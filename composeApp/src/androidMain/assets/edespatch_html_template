<body style="margin-left=0.6in; margin-right=0.6in; margin-top=0.79in; margin-bottom=0.79in">
<table cellpadding="0px" width="800" cellspacing="0px" border="0" style="border-color:blue; ">
    <tbody>
    <tr valign="top">
        <td width="40%">
            <br>
            <hr>
            <table width="100%" border="0" align="center">
                <tbody>
                <tr align="left">
                    <td align="left">{FIRM_NAME}<br></td>
                </tr>
                <tr align="left">
                    <td align="left">{FIRM_ADDRESS}&nbsp;<br>{FIRM_COUNTY}/ {FIRM_CITY}&nbsp;</td>
                </tr>
                <tr align="left">
                    <td align="left">Tel: {FIRM_PHONE} Fax: {FIRM_FAX}&nbsp;</td>
                </tr>
                <tr align="left">
                    <td>Web Sitesi: {FIRM_WEBURL}</td>
                </tr>
                <tr align="left">
                    <td>E-Posta: {FIRM_EMAIL}</td>
                </tr>
                <tr align="left">
                    <td align="left">Vergi Dairesi: {FIRM_TAXOFFICE}&nbsp; </td>
                </tr>
                <tr align="left">
                    <td>VKN: {FIRM_TAXNUMBER}</td>
                </tr>
                </tbody>
            </table>
            <hr>
        </td>
        <td valign="middle" align="center" width="20%">
            <br><br><img src="data:image/jpeg;base64," alt="E-Fatura Logo" align="middle" style="width:91px;">
            <h1 align="center"><span style="font-weight:bold; ">e-İRSALİYE</span></h1>
        </td>
        <td align="right" valign="middle" width="40%"><img src="data:image/jpeg;base64," alt="Firma Logo" style="max-width:320px; max-height:180px;"></td>
    </tr>
    <tr valign="top" style="height:118px; ">
        <td valign="bottom" align="right" width="40%">
            <table border="0" align="left" id="customerPartyTable">
                <tbody>
                <tr style="height:71px; ">
                    <td>
                        <hr>
                        <table border="0" align="center">
                            <tbody>
                            <tr>
                                <td align="left" style="width:469px; "><span style="font-weight:bold; ">SAYIN</span></td>
                            </tr>
                            <tr>
                                <td align="left" style="width:469px; ">{CUSTOMER_NAME}<br></td>
                            </tr>
                            <tr>
                                <td align="left" style="width:469px; ">{CUSTOMER_ADRESS}&nbsp;<br>{CUSTOMER_COUNTY}/ {CUSTOMER_CITY}&nbsp;</td>
                            </tr>
                            <tr align="left">
                                <td>Web Sitesi: {CUSTOMER_WEBURL}</td>
                            </tr>
                            <tr align="left">
                                <td>E-Posta: {CUSTOMER_EMAIL}</td>
                            </tr>
                            <tr align="left">
                                <td align="left" style="width:469px; ">Tel: {CUSTOMER_PHONE} Fax: {CUSTOMER_FAX}</td>
                            </tr>
                            <tr align="left">
                                <td>Vergi Dairesi: {CUSTOMER_TAXOFFICE}</td>
                            </tr>
                            <tr align="left">
                                <td>VKN: {CUSTOMER_TAXNUMBER}</td>
                            </tr>
                            </tbody>
                        </table>
                        <hr>
                    </td>
                </tr>
                </tbody>
            </table>
            <br>
        </td>
        <td style="padding-left:55px;" valign="center"><img alt="QrCode" align="middle" style="width:100px; height:100px;" src="data:image/jpeg;base64,{QRCODE}"></td>
        <td colspan="2" valign="bottom" align="center" width="60%">
            <table id="despatchTable" border="1">
                <tbody>
                <tr>
                    <td align="left" style="width:105px;"><span style="font-weight:bold; ">Özelleştirme No:</span></td>
                    <td align="left" style="width:110px;">TR1.2.1</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">Senaryo:</span></td>
                    <td align="left">TEMELIRSALIYE</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">İrsaliye Tipi:</span></td>
                    <td align="left">SEVK</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">İrsaliye No:</span></td>
                    <td align="left">{FICHENO}</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">İrsaliye Tarihi:</span></td>
                    <td align="left">{DOC_DATE}</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">İrsaliye Zamanı:</span></td>
                    <td align="left">{DOC_TIME}</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">Sevk Tarihi:</span></td>
                    <td align="left">{SHIP_DATE}</td>
                </tr>
                <tr style="height:13px; ">
                    <td align="left"><span style="font-weight:bold; ">Sevk Zamanı:</span></td>
                    <td align="left">{SHIP_TIME}</td>
                </tr>
                </tbody>
            </table>
        </td>
    </tr>
    <tr align="left">
        <td id="ettnTable" valign="top" align="left"><span style="font-weight:bold; ">ETTN:&nbsp;</span>{ETTN}</td>
    </tr>
    </tbody>
</table>
<div id="lineTableAligner"><span>&nbsp;</span></div>
<table width="800" id="lineTable" border="1">
    <tbody>
    <tr class="lineTableTr">
        <td align="center" style="width:5%" class="lineTableTd"><span style="font-weight:bold;">Sıra No</span></td>
        <td align="center" style="width:35%" class="lineTableTd"><span style="font-weight:bold;">Mal</span></td>
        <td align="center" style="width:10%" class="lineTableTd"><span style="font-weight:bold;">Miktar</span></td>
        <td align="center" style="width:10%" class="lineTableTd"><span style="font-weight:bold;">Birim Fiyat</span></td>
        <td align="center" style="width:20%" class="lineTableTd"><span style="font-weight:bold;">Sonra Gönderilecek Miktar</span></td>
        <td align="center" style="width:20%" class="lineTableTd"><span style="font-weight:bold;">Tutar</span></td>
    </tr>
    {FICHE_LINES}
    </tbody>
</table>
<table width="800px" id="budgetContainerTable">
    <tbody>
    <tr align="right">
        <td></td>
        <td width="156px" align="right" class="lineTableBudgetTd"><span style="font-weight:bold; ">Toplam Tutar</span></td>
        <td align="right" style="width:156px; " class="lineTableBudgetTd">{FICHE_TOTAL} {PRICE_CURRENCY}</td>
    </tr>
    </tbody>
</table>
<br><br>
<table align="left" width="800" id="notesTable">
    <thead>
    <tr>
        <td align="left"><span align="center" style="font-weight:bold; ">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Açıklamalar</span></td>
        <td align="left"><span align="center" style="font-weight:bold; ">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Taşıyıcı Bilgileri</span></td>
        <td align="left"><span align="center" style="font-weight:bold; ">Sürücü Bilgileri</span></td>
    </tr>
    </thead>
    <tbody>
    <tr align="left">
        <td height="100" id="notesTableTd">
            <b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</b><br>
            <p id="firmNotes"></p>
        </td>
        <td height="100" id="notesTableTd"><b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Taşıyıcı Firma: </b>
            VKN: {SHIPAGENT_TAXNUMBER}, {SHIPAGENT_TITLE}
        </td>
        <td height="100" id="notesTableTd">
            <b>&nbsp; Araç Plaka Numarası: </b> {VEHICLE_PLATE_NUMBER}
            <br>
            <b>&nbsp; Dorse Plaka Numarası: </b> {TRAILER_PLATE_NUMBER}
            <br>
            <b>&nbsp; Şoför Ad/Soyad: </b> {DRIVER_NAME_SURNAME}
            <br>
            <b>&nbsp; Şoför TCKN: </b> {DRIVER_IDENTITY_NUMBER}
        </td>
    </tr>
    </tbody>
</table>
