<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
                                                     android:id="@+id/cord_frame"
                                                     android:layout_width="match_parent"
                                                     android:layout_height="match_parent">
	<RelativeLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent">
		<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/rcwList"
				android:layout_width="match_parent"
				android:layout_height="match_parent"/>
	</RelativeLayout>
	<com.google.android.material.floatingactionbutton.FloatingActionButton
			android:id="@+id/fab_penetration"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_margin="@dimen/fab_margin"
			android:src="@drawable/ic_create_white_48dp"
			app:backgroundTint="@color/colorPrimary"
			app:elevation="6dp"
			app:fabSize="normal"
			app:layout_anchor="@+id/rcwList"
			app:layout_anchorGravity="end|bottom"
			app:pressedTranslationZ="12dp"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
