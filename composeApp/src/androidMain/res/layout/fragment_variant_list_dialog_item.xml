<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:bind="http://schemas.android.com/apk/res-auto"
                                                   android:gravity="center_vertical" android:orientation="vertical"
                                                   android:tag="layout/fragment_variant_list_dialog_item_0"
                                                   android:background="@android:color/transparent"
                                                   android:paddingLeft="@dimen/padding" android:paddingTop="5dp"
                                                   android:paddingRight="@dimen/padding" android:paddingBottom="5dp"
                                                   android:focusableInTouchMode="true"
                                                   android:descendantFocusability="beforeDescendants"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="wrap_content"
                                                   android:cacheColorHint="@android:color/transparent"
                                                   android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
    <HorizontalScrollView android:id="@+id/hvCode" android:paddingTop="5dp" android:paddingBottom="5dp"
                          android:layout_width="0dp" android:layout_height="wrap_content"
                          bind:layout_constraintEnd_toStartOf="@+id/guideline70"
                          bind:layout_constraintStart_toStartOf="parent" bind:layout_constraintTop_toTopOf="parent">
        <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:scrollbarStyle="insideOverlay"
                  android:ellipsize="end" android:id="@+id/tvCode" android:tag="binding_1"
                  android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1"
                  android:scrollHorizontally="true"/>
    </HorizontalScrollView>
    <HorizontalScrollView android:id="@+id/hvName" android:paddingBottom="5dp" android:layout_width="0dp"
                          android:layout_height="wrap_content" bind:layout_constraintEnd_toStartOf="@+id/guideline70"
                          bind:layout_constraintStart_toStartOf="parent" bind:layout_constraintTop_toBottomOf="@+id/hvCode">
        <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:scrollbarStyle="insideOverlay"
                  android:ellipsize="end" android:id="@+id/tvVariantName" android:tag="binding_2"
                  android:layout_width="wrap_content" android:layout_height="wrap_content" android:lines="1"
                  android:scrollHorizontally="true"/>
    </HorizontalScrollView>
    <androidx.appcompat.widget.AppCompatEditText android:textAppearance="?android:attr/textAppearanceSmall"
                                                 android:gravity="end" android:id="@+id/edtUserAmount"
                                                 android:tag="binding_3" android:focusable="true"
                                                 android:clickable="true" android:layout_width="0dp"
                                                 android:layout_height="wrap_content" android:singleLine="true"
                                                 android:selectAllOnFocus="true" android:inputType="numberDecimal"
                                                 android:imeOptions="actionGo|actionSend|actionDone|flagNoFullscreen"
                                                 android:layout_marginStart="4dp" android:layout_marginEnd="4dp"
                                                 bind:layout_constraintBottom_toBottomOf="@+id/hvName"
                                                 bind:layout_constraintEnd_toStartOf="@+id/guideline90"
                                                 bind:layout_constraintStart_toEndOf="@+id/guideline70"
                                                 bind:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatCheckBox android:id="@+id/cbListItem" android:tag="binding_4"
                                                 android:focusable="true" android:focusableInTouchMode="false"
                                                 android:clickable="true" android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:layout_marginStart="8dp"
                                                 android:layout_marginEnd="8dp"
                                                 bind:layout_constraintBottom_toBottomOf="@+id/hvName"
                                                 bind:layout_constraintEnd_toEndOf="parent"
                                                 bind:layout_constraintStart_toStartOf="@+id/guideline90"
                                                 bind:layout_constraintTop_toTopOf="parent"/>
    <TextView android:ellipsize="end" android:id="@+id/txt_product_actual_stock_text" android:layout_width="0dp"
              android:layout_height="wrap_content" android:text="@string/str_physical_stock" android:maxLines="1"
              android:paddingStart="0dp" android:paddingEnd="0dp" bind:layout_constraintEnd_toEndOf="@+id/guideline20"
              bind:layout_constraintStart_toStartOf="parent" bind:layout_constraintTop_toBottomOf="@+id/hvName"
              style="@style/textCustomerSubtitleStyle"/>
    <TextView android:textStyle="bold" android:ellipsize="end" android:id="@+id/txt_product_actual_stock"
              android:tag="binding_5" android:layout_width="0dp" android:layout_height="wrap_content"
              android:maxLines="4" android:layout_weight="3" bind:layout_constraintEnd_toStartOf="@+id/guideline50"
              bind:layout_constraintStart_toEndOf="@+id/guideline20" bind:layout_constraintTop_toBottomOf="@+id/hvName"
              style="@style/textCustomerSubtitleNumberStyle"/>
    <TextView android:ellipsize="end" android:id="@+id/txt_product_defined_price" android:layout_width="0dp"
              android:layout_height="wrap_content" android:text="@string/str_defined_price_abbr" android:maxLines="1"
              android:layout_weight="2" android:paddingStart="0dp" android:paddingEnd="0dp"
              bind:layout_constraintEnd_toStartOf="@+id/guideline70"
              bind:layout_constraintStart_toEndOf="@+id/guideline50" bind:layout_constraintTop_toBottomOf="@+id/hvName"
              style="@style/textCustomerSubtitleStyle"/>
    <TextView android:textStyle="bold" android:ellipsize="end" android:id="@+id/txt_definedPrice"
              android:tag="binding_6" android:layout_width="0dp" android:layout_height="wrap_content"
              android:maxLines="4" android:layout_weight="3" bind:layout_constraintEnd_toEndOf="parent"
              bind:layout_constraintStart_toEndOf="@+id/guideline70" bind:layout_constraintTop_toBottomOf="@+id/hvName"
              style="@style/textCustomerSubtitleNumberStyle"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/guideline70"
                                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                bind:layout_constraintGuide_percent="0.7"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/guideline90"
                                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                bind:layout_constraintGuide_percent="0.9"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/guideline20"
                                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                bind:layout_constraintGuide_percent="0.2"/>
    <androidx.constraintlayout.widget.Guideline android:orientation="vertical" android:id="@+id/guideline50"
                                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                bind:layout_constraintGuide_percent="0.5"/>
</androidx.constraintlayout.widget.ConstraintLayout>