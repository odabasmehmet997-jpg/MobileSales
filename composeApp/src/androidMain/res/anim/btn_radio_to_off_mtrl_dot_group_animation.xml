<?xml version="1.0" encoding="utf-8"?>
<set xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android">
    <set android:ordering="sequentially">
        <objectAnimator android:interpolator="@anim/fast_out_slow_in" android:duration="183"
                        android:valueFrom="1" android:valueTo="1.4" android:valueType="floatType"
                        android:propertyName="scaleX"/>
        <objectAnimator android:interpolator="@anim/fast_out_slow_in" android:duration="16"
                        android:valueFrom="1.4" android:valueTo="0" android:valueType="floatType"
                        android:propertyName="scaleX"/>
        <objectAnimator android:interpolator="@anim/fast_out_slow_in" android:duration="300"
                        android:valueFrom="0" android:valueTo="0" android:valueType="floatType"
                        android:propertyName="scaleX"/>
    </set>
    <set android:ordering="sequentially">
        <objectAnimator android:interpolator="@anim/fast_out_slow_in" android:duration="183"
                        android:valueFrom="1" android:valueTo="1.4" android:valueType="floatType"
                        android:propertyName="scaleY" tools:ignore="PrivateResource"/>
        <objectAnimator android:interpolator="@anim/fast_out_slow_in" android:duration="16"
                        android:valueFrom="1.4" android:valueTo="0" android:valueType="floatType"
                        android:propertyName="scaleY" tools:ignore="PrivateResource"/>
        <objectAnimator android:interpolator="@anim/fast_out_slow_in" android:duration="300"
                        android:valueFrom="0" android:valueTo="0" android:valueType="floatType"
                        android:propertyName="scaleY" tools:ignore="PrivateResource"/>
    </set>
