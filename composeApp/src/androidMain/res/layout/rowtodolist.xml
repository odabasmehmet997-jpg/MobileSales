<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
                android:paddingLeft="15dp" android:paddingTop="10dp" android:paddingBottom="10dp"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="15dp">
    <androidx.appcompat.widget.AppCompatTextView android:textSize="18dp" android:id="@+id/TBEGDATE"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:text="111111"/>
    <androidx.appcompat.widget.AppCompatTextView android:textSize="18dp" android:id="@+id/VAYRAC"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:text=" / "
                                                 android:layout_toRightOf="@+id/TBEGDATE"
                                                 android:layout_alignTop="@+id/TBEGDATE"
                                                 android:layout_toEndOf="@+id/TBEGDATE"/>
    <androidx.appcompat.widget.AppCompatTextView android:textSize="18dp" android:id="@+id/TENDDATE"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:text="111111"
                                                 android:layout_toRightOf="@+id/VAYRAC"
                                                 android:layout_alignTop="@+id/VAYRAC"
                                                 android:layout_toEndOf="@+id/VAYRAC"/>
    <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                 android:textColor="@color/subMenu3" android:id="@+id/TPRIORITYSTR"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:text="2222222"
                                                 android:layout_below="@+id/TBEGDATE"/>
    <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                 android:textColor="@color/subMenu3" android:id="@+id/TAYRAC2"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:layout_marginLeft="5dp"
                                                 android:text="/" android:layout_toRightOf="@+id/TPRIORITYSTR"
                                                 android:layout_alignTop="@+id/TPRIORITYSTR"
                                                 android:layout_marginStart="5dp"
                                                 android:layout_toEndOf="@+id/TPRIORITYSTR"/>
    <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                 android:textColor="@color/subMenu3" android:id="@+id/TSTATUSSTR"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:layout_marginLeft="5dp"
                                                 android:text="2222222" android:layout_toRightOf="@+id/TAYRAC2"
                                                 android:layout_below="@+id/TBEGDATE"
                                                 android:layout_alignTop="@+id/TAYRAC2" android:layout_marginStart="5dp"
                                                 android:layout_toEndOf="@+id/TAYRAC2"/>
    <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                 android:textColor="@color/subMenu6" android:id="@+id/TDESC"
                                                 android:layout_width="wrap_content"
                                                 android:layout_height="wrap_content" android:text="333333"
                                                 android:layout_below="@+id/TSTATUSSTR"/>
    <androidx.appcompat.widget.AppCompatTextView android:id="@+id/TODOID" android:layout_width="0px"
                                                 android:layout_height="0px" android:text="TextView"
                                                 android:layout_x="0px" android:layout_y="0px"/>
</RelativeLayout>