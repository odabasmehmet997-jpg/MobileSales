<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout android:id="@+id/rlt_container" android:padding="@dimen/padding_custom_view"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:id="@+id/txt_productName" android:layout_width="match_parent"
                  android:layout_height="wrap_content" style="@style/textSubtitleStyle"/>
        <TextView android:textSize="@dimen/text_size_xl_small" android:id="@+id/txt_productCode"
                  android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:layout_marginTop="1dp" android:maxLines="1" android:layout_below="@+id/txt_productName"
                  style="@style/textSubtitleStyle"/>
        <TextView android:textStyle="bold" android:id="@+id/txt_productTotal" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:layout_marginTop="2dp" android:singleLine="false"
                  android:layout_below="@+id/txt_productCode" android:layout_toStartOf="@+id/btn_productInfo"
                  android:layout_alignParentStart="true" style="@style/textSubtitleStyle"/>
        <TextView android:textStyle="bold" android:id="@+id/txt_productTotalWithCurrency" android:visibility="gone"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:layout_marginTop="2dp" android:singleLine="false" android:layout_below="@+id/txt_productTotal"
                  android:layout_toStartOf="@+id/btn_productInfo" android:layout_alignParentStart="true"
                  style="@style/textSubtitleStyle"/>
        <LinearLayout android:orientation="horizontal" android:id="@+id/ln_discount_rate"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:layout_below="@+id/txt_productTotalWithCurrency">
            <TextView android:textStyle="bold" android:id="@+id/txt_discount_rate_header"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:layout_marginTop="2dp" android:layout_below="@+id/txt_productTotalWithCurrency"
                      android:layout_alignStart="@+id/txt_productTotal" style="@style/textSubtitleStyle"/>
            <TextView android:id="@+id/txt_discount_rate" android:padding="0dp" android:layout_width="wrap_content"
                      android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="1"
                      android:layout_below="@+id/txt_productTotalWithCurrency" android:layout_marginEnd="5dp"
                      android:layout_toStartOf="@+id/txt_productUnitPrice"
                      android:layout_toEndOf="@+id/txt_discount_rate_header" style="@style/textSubtitleStyle"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:id="@+id/ln_barcode_count"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:layout_below="@+id/txt_productVariantHeader">
            <TextView android:textStyle="bold" android:id="@+id/txt_barcode_count_header"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:layout_marginTop="2dp" android:text="@string/str_barcode_count"
                      android:layout_below="@+id/txt_productVariantHeader"
                      android:layout_alignStart="@+id/txt_productTotal" style="@style/textSubtitleStyle"/>
            <TextView android:id="@+id/txt_barcode_count" android:padding="0dp" android:layout_width="match_parent"
                      android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="1"
                      android:layout_below="@+id/txt_productVariant" android:layout_marginEnd="5dp"
                      android:layout_toStartOf="@+id/txt_productUnitPrice"
                      android:layout_toEndOf="@+id/txt_barcode_count_header" style="@style/textSubtitleStyle"/>
        </LinearLayout>
        <TextView android:textStyle="bold" android:id="@+id/txt_productUnitPrice" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:layout_marginTop="2dp" android:singleLine="false"
                  android:layout_below="@+id/txt_productTotalWithCurrency" android:layout_alignParentEnd="true"
                  style="@style/textSubtitleStyle"/>
        <ImageButton android:id="@+id/btn_productInfo" android:background="@android:color/transparent"
                     android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content"
                     android:layout_centerVertical="true" android:layout_toStartOf="@+id/btn_productDetail"
                     app:srcCompat="@drawable/ic_information_outline_grey600_18dp"/>
        <ImageView android:id="@+id/btn_productDetail" android:layout_width="wrap_content"
                   android:layout_height="wrap_content" android:src="@drawable/ic_chevron_right_grey600_24dp"
                   android:layout_centerVertical="true" android:layout_alignParentEnd="true"/>
        <ImageView android:id="@+id/btn_productOperation" android:layout_width="wrap_content"
                   android:layout_height="wrap_content" android:layout_marginBottom="5dp"
                   android:src="@drawable/ic_dots_vertical_grey600_18dp"
                   android:layout_alignBottom="@+id/btn_productDetail" android:layout_alignParentTop="true"
                   android:rotation="90" android:layout_marginEnd="2dp" android:layout_alignParentEnd="true"/>
        <TextView android:textStyle="bold" android:id="@+id/txt_promotion" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:text="P"
                  android:layout_toStartOf="@+id/btn_productDetail" style="@style/textSubtitleStyle"/>
        <TextView android:textStyle="bold" android:id="@+id/txt_surplusAmountHeader" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:layout_marginTop="2dp"
                  android:text="@string/str_surplus_amount_abbr" android:layout_below="@+id/ln_discount_rate"
                  android:layout_alignStart="@+id/txt_productTotal" style="@style/textSubtitleStyle"/>
        <TextView android:id="@+id/txt_surplusAmount" android:padding="0dp" android:layout_width="match_parent"
                  android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="1"
                  android:layout_below="@+id/ln_discount_rate" android:layout_marginEnd="5dp"
                  android:layout_toEndOf="@+id/txt_surplusAmountHeader" style="@style/textSubtitleStyle"/>
        <TextView android:textStyle="bold" android:id="@+id/txt_productVariantHeader"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:layout_marginTop="2dp" android:text="@string/str_variant_colon"
                  android:layout_below="@+id/txt_surplusAmountHeader"
                  android:layout_alignStart="@+id/txt_surplusAmountHeader" style="@style/textSubtitleStyle"/>
        <TextView android:id="@+id/txt_productVariant" android:padding="0dp" android:layout_width="match_parent"
                  android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="1"
                  android:layout_below="@+id/txt_surplusAmountHeader" android:layout_marginEnd="5dp"
                  android:layout_toEndOf="@+id/txt_productVariantHeader" style="@style/textSubtitleStyle"/>
    </RelativeLayout>
</merge>