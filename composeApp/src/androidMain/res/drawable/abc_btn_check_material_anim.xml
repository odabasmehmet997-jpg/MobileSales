<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:id="@+id/checked"/>
    <item android:id="@+id/unchecked"/>
    <transition android:toId="@+id/checked" android:fromId="@+id/unchecked"/>
    <transition android:toId="@+id/unchecked" android:fromId="@+id/checked"/>
</animated-selector>