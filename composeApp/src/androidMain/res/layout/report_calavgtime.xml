<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="match_parent">
    <include layout="@layout/toolbar"/>
    <LinearLayout android:gravity="bottom" android:orientation="horizontal" android:id="@+id/linearFilterDiv"
                  android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:baselineAligned="false" android:layout_weight="1">
        <LinearLayout android:gravity="bottom" android:orientation="vertical" android:layout_width="0dp"
                      android:layout_height="wrap_content" android:layout_weight="1">
            <include android:id="@+id/linearDateLayout" layout="@layout/activity_base_report_wcf"/>
        </LinearLayout>
        <LinearLayout android:layout_gravity="top" android:layout_width="0dp" android:layout_height="match_parent"
                      android:layout_marginLeft="4dp" android:layout_marginBottom="1dp" android:layout_weight="1.25"
                      android:layout_marginStart="4dp" style="@style/editCalendar">
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:id="@+id/imgList"
                                                            android:layout_width="match_parent"
                                                            android:layout_height="match_parent"
                                                            android:src="@android:drawable/ic_search_category_default"
                                                            android:scaleType="fitCenter"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:layout_marginTop="2dp" android:layout_weight="1">
        <View android:layout_gravity="center_vertical" android:background="#55e2e1e1" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp" android:layout_marginTop="1dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="@color/line_color"
              android:paddingBottom="1dp" android:layout_width="match_parent" android:layout_height="0.1sp"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="@color/line_color"
              android:paddingBottom="1dp" android:layout_width="match_parent" android:layout_height="0.1sp"/>
    </LinearLayout>
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="100">
        <LinearLayout android:gravity="bottom|center_vertical|center_horizontal|center"
                      android:layout_gravity="bottom|center_vertical|center_horizontal|center"
                      android:id="@+id/linearProgress" android:layout_width="match_parent"
                      android:layout_height="match_parent">
            <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:gravity="center_vertical" android:orientation="vertical"
                      android:background="@android:color/transparent" android:layout_width="match_parent"
                      android:layout_height="wrap_content">
            <View android:layout_gravity="center_vertical" android:background="#55e2e1e1" android:paddingBottom="1dp"
                  android:layout_width="match_parent" android:layout_height="0.1sp"/>
            <Space android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                          android:layout_width="match_parent" android:layout_height="match_parent">
                <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                             android:textStyle="bold" android:id="@+id/txtViewDebitDate"
                                                             android:layout_width="0dp"
                                                             android:layout_height="wrap_content"
                                                             android:layout_marginRight="4dp" android:text="Tarih:"
                                                             android:singleLine="false" android:layout_weight="5"
                                                             android:layout_marginEnd="4dp"/>
                <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                             android:textStyle="bold"
                                                             android:id="@+id/txtViewDebitCalDay"
                                                             android:layout_width="0dp"
                                                             android:layout_height="wrap_content" android:text="Gün:0"
                                                             android:singleLine="false" android:layout_weight="5"/>
                <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                             android:textStyle="bold"
                                                             android:id="@+id/txtViewDebitCalTotal"
                                                             android:layout_width="0dp"
                                                             android:layout_height="wrap_content"
                                                             android:text="Toplam Borç:0" android:singleLine="false"
                                                             android:layout_weight="5"/>
            </LinearLayout>
            <Space android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
            <Space android:layout_width="0dp" android:layout_height="10dp" android:layout_weight="1"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                          android:layout_width="match_parent" android:layout_height="match_parent">
                <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                             android:textStyle="bold"
                                                             android:id="@+id/txtViewCreditCalDate"
                                                             android:layout_width="0dp"
                                                             android:layout_height="wrap_content"
                                                             android:layout_marginRight="4dp" android:text="Tarih:"
                                                             android:singleLine="false" android:layout_weight="5"
                                                             android:layout_marginEnd="4dp"/>
                <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                             android:textStyle="bold"
                                                             android:id="@+id/txtViewCreditCalDay"
                                                             android:layout_width="0dp"
                                                             android:layout_height="wrap_content" android:text="Gün:0"
                                                             android:singleLine="false" android:layout_weight="5"/>
                <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                             android:textStyle="bold"
                                                             android:id="@+id/txtViewCreditCalTotal"
                                                             android:layout_width="0dp"
                                                             android:layout_height="wrap_content"
                                                             android:text="Toplam Alacak:0" android:singleLine="false"
                                                             android:layout_weight="5"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>