<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="16sp"
              android:layout_marginRight="6sp" android:layout_marginStart="16sp" android:layout_marginEnd="6sp">
    <TextView android:textAppearance="?android:attr/textAppearanceMedium"
              android:textColor="?android:attr/textColorPrimary" android:id="@android:id/title"
              android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="1"/>
    <TextView android:textAppearance="?android:attr/textAppearanceSmall"
              android:textColor="?android:attr/textColorSecondary" android:id="@android:id/summary"
              android:layout_width="wrap_content" android:layout_height="wrap_content" android:maxLines="2"/>
    <View android:background="@color/blackT12" android:layout_width="match_parent"
          android:layout_height="@dimen/divider" android:layout_marginTop="@dimen/padding_text"/>
</LinearLayout>
