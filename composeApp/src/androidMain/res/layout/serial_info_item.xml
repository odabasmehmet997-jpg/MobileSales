<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="horizontal" android:paddingTop="5dp" android:paddingBottom="5dp"
                  android:layout_width="match_parent" android:layout_height="wrap_content">
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="match_parent"
                              android:layout_weight="1">
            <TextView android:scrollbarStyle="insideOverlay" android:id="@+id/txt_serial_no_1"
                      android:layout_width="0dp" android:layout_height="wrap_content" android:scrollHorizontally="true"
                      android:layout_weight="1" style="@style/textCustomerSubtitleStyle"/>
        </HorizontalScrollView>
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="match_parent"
                              android:layout_weight="1">
            <TextView android:scrollbarStyle="insideOverlay" android:id="@+id/txt_serial_no_2"
                      android:layout_width="0dp" android:layout_height="wrap_content" android:scrollHorizontally="true"
                      android:layout_weight="1" style="@style/textCustomerSubtitleStyle"/>
        </HorizontalScrollView>
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="match_parent"
                              android:layout_weight="1">
            <TextView android:scrollbarStyle="insideOverlay" android:id="@+id/txt_product_stock"
                      android:layout_width="0dp" android:layout_height="wrap_content" android:scrollHorizontally="true"
                      android:layout_weight="1" style="@style/textCustomerSubtitleStyle"/>
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>