<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools"
              android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView android:scrollbarStyle="insideOverlay" android:scrollbars="vertical"
                                           android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent"
                      android:layout_height="wrap_content">
            <com.proje.mobilesales.core.widget.TintableTextView android:layout_width="match_parent"
                                                                android:layout_height="wrap_content"
                                                                android:text="@string/str_ship_account"
                                                                android:textAllCaps="true"
                                                                style="@style/TintableTitleStyle"/>
            <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                  android:layout_height="2dp"/>
            <LinearLayout android:id="@+id/ln_visitShipAddress" android:layout_width="match_parent"
                          android:layout_height="wrap_content" android:weightSum="1">
                <TextView android:layout_width="0dp" android:layout_height="match_parent"
                          android:text="@string/str_ship_address" android:layout_weight="0.45"
                          android:textAllCaps="true" style="@style/textCustomerSalesHeaderStyle"/>
                <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent"
                                android:layout_weight="0.55">
                    <TextView android:textStyle="bold" android:id="@+id/txt_visitShipAddress"
                              android:layout_width="match_parent" android:layout_height="match_parent"
                              android:singleLine="false" android:layout_toLeftOf="@+id/img_visitShipAddressDelete"
                              android:layout_alignParentLeft="true"
                              android:layout_toStartOf="@+id/img_visitShipAddressDelete"
                              android:layout_alignParentStart="true" style="@style/textCustomerSalesHeaderStyle"/>
					<ImageView android:id="@+id/img_visitShipAddressDelete" android:visibility="gone"
	                           android:layout_width="wrap_content" android:layout_height="wrap_content"
	                           android:src="@drawable/ic_close_circle_grey600_24dp"
	                           android:layout_alignParentEnd="true"
	                           style="@style/textCustomerSalesHeaderStyle"/>
                </RelativeLayout>
            </LinearLayout>
            <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                  android:layout_height="1dp"/>
            <com.proje.mobilesales.core.widget.TintableTextView android:layout_width="match_parent"
                                                                android:layout_height="wrap_content"
                                                                android:text="@string/str_visit_info"
                                                                android:textAllCaps="true"
                                                                style="@style/TintableTitleStyle"/>
            <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                  android:layout_height="2dp"/>
            <LinearLayout android:id="@+id/ln_visitReasonSelect" android:layout_width="match_parent"
                          android:layout_height="wrap_content" android:weightSum="1">
                <TextView android:layout_gravity="left|center_vertical|center_horizontal|center|start"
                          android:layout_width="0dp" android:layout_height="match_parent"
                          android:text="@string/str_visit_reason" android:layout_weight="0.45"
                          android:textAllCaps="true" style="@style/textCustomerSalesHeaderStyle"/>
                <TextView android:textStyle="bold" android:id="@+id/txt_visitReasonSelect" android:layout_width="0dp"
                          android:layout_height="match_parent" android:layout_weight="0.55"
                          style="@style/textCustomerSalesHeaderStyle"/>
            </LinearLayout>
            <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                  android:layout_height="1dp"/>
            <LinearLayout android:id="@+id/ln_visitUserTitle" android:layout_width="match_parent"
                          android:layout_height="wrap_content" android:weightSum="1">
                <TextView
                          android:id="@+id/textView4" android:layout_width="0dp" android:layout_height="match_parent"
                          android:text="@string/str_visit_user_title" android:layout_weight="0.45"
                          android:textAllCaps="true" style="@style/textCustomerSalesHeaderStyle"/>
                <TextView android:textStyle="bold" android:id="@+id/txt_visitUserTitle" android:layout_width="0dp"
                          android:layout_height="match_parent" android:layout_weight="0.55"
                          style="@style/textCustomerSalesHeaderStyle"/>
            </LinearLayout>
            <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                  android:layout_height="1dp"/>
            <LinearLayout android:id="@+id/ln_visitNote" android:layout_width="match_parent"
                          android:layout_height="wrap_content" android:weightSum="1">
                <TextView android:layout_gravity="left|center_vertical|center_horizontal|center|start"
                          android:id="@+id/textView3" android:layout_width="0dp" android:layout_height="match_parent"
                          android:text="@string/str_note" android:layout_weight="0.45" android:textAllCaps="true"
                          style="@style/textCustomerSalesHeaderStyle"/>
                <EditText android:textStyle="bold" android:id="@+id/edt_visitNote" android:scrollbars="vertical"
                          android:layout_width="0dp" android:layout_height="match_parent" android:maxLines="10"
                          android:lines="10" android:minLines="1" android:singleLine="false"
                          android:layout_weight="0.55" android:inputType="textMultiLine"
                          style="@style/textCustomerSalesHeaderStyle" android:hint=""
                          tools:ignore="SpeakableTextPresentCheck"/>
            </LinearLayout>
            <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                  android:layout_height="1dp"/>
            <ImageView android:id="@+id/img_visit" android:padding="@dimen/half_padding"  android:layout_alignParentEnd="true"
                       android:layout_width="match_parent" android:layout_height="256dp" android:scaleType="fitCenter"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
