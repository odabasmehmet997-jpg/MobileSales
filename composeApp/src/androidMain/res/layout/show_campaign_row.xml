<?xml version='1.0' encoding='utf-8'?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:orientation="vertical"
              android:padding="5.0dp"
              android:layout_width="fill_parent"
              android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:id="@id/tvType"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/str_material"
                    android:singleLine="true"
                    android:layout_weight="2.0"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <View android:layout_gravity="center_horizontal"
              android:background="#77e2e1e1"
              android:layout_width="fill_parent"
              android:layout_height="1.0sp"/>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/linearMaterial1"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      tools:ignore="ExtraText,SpeakableTextPresentCheck">
            android:id="@id/linearMaterial1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textStyle="bold"
                    android:id="@id/tvCode"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="DT008"
                    android:singleLine="true"
                    android:layout_weight="2.0"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textStyle="bold"
                    android:id="@+id/tvName"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="LIMONLU SIVI SABUN"
                    android:singleLine="true"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@id/linearMaterial2"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_quantity_unit"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/tvQuantityUnit"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="ADET"
                                                         android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnDiscountRatio"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_discount_ratio"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmallInverse"
                    android:id="@+id/tvDiscountRate"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnDiscount1"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_discount1"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmallInverse"
                    android:id="@+id/tvDiscount1"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnDiscount2"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_discount2"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmallInverse"
                    android:id="@+id/tvDiscount2"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnDiscount3"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="10.0dp"
                    android:gravity="end"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/str_discount3"
                    android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmallInverse"
                    android:id="@+id/tvDiscount3"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnCampaignPoint"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_point"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmallInverse"
                    android:id="@+id/tvCampaignPoint"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnSurplus"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_surplus_amount"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:id="@+id/tvSurplusQuantityUnit"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="ADET"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal"
                      android:id="@+id/lnSurplusDiscount"
                      android:layout_width="fill_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerInParent="true">
            <androidx.appcompat.widget.AppCompatTextView android:textSize="10.0dp"
                                                         android:gravity="end"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_surplus_discount"
                                                         android:layout_weight="2.0" tools:ignore="TextSizeCheck"/>
            <View android:layout_gravity="center_vertical"
                  android:background="#77e2e1e1"
                  android:layout_width="2.0dp"
                  android:layout_height="14.0dp"
                  android:layout_marginLeft="5.0dp"
                  android:layout_marginRight="5.0dp"
                  android:layout_marginStart="5.0dp"
                  android:layout_marginEnd="5.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:id="@id/tvSurplusDiscount"
                    android:layout_width="0.0dp"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:layout_weight="5.0"/>
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatImageView
                android:layout_gravity="center_vertical"
                android:id="@id/imSpinner"
                android:visibility="gone"
                android:layout_width="35.0dp"
                android:layout_height="35.0dp"
                android:scaleType="fitCenter"/>
    </LinearLayout>
</LinearLayout>