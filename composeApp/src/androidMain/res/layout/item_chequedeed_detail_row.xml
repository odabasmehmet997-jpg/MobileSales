<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
                                   android:layout_width="match_parent"
                                   android:layout_height="wrap_content"
                                   style="@style/AppCardView">
	<LinearLayout
			android:orientation="vertical"
			android:id="@+id/ln_detailContainer"
			android:padding="@dimen/fiche_padding"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="@dimen/margin">
		<LinearLayout
				android:orientation="horizontal"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:weightSum="1">
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:gravity="center_vertical"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:text="@string/str_total"
					android:layout_weight="0.15"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:textStyle="bold"
					android:gravity="center_vertical"
					android:id="@+id/txt_amount"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_weight="0.35"
					android:inputType="numberDecimal"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:gravity="center_vertical"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:text="@string/str_expiry"
					android:layout_weight="0.25"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:textStyle="bold"
					android:gravity="center_vertical"
					android:id="@+id/txt_expiry"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:maxLength="17"
					android:layout_weight="0.25"/>
		</LinearLayout>
		<LinearLayout
				android:orientation="horizontal"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:weightSum="1">
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:gravity="center_vertical"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:text="@string/str_bank_branch"
					android:layout_weight="0.15"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:textStyle="bold"
					android:gravity="center_vertical"
					android:id="@+id/txt_branch"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_weight="0.35"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:gravity="center_vertical"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:text="@string/str_account_number"
					android:layout_weight="0.25"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:textStyle="bold"
					android:gravity="center_vertical"
					android:id="@+id/txt_accountNo"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:maxLength="17"
					android:layout_weight="0.25"/>
		</LinearLayout>
		<LinearLayout
				android:orientation="horizontal"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:weightSum="1">
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:gravity="center_vertical"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:text="@string/str_debtor"
					android:layout_weight="0.15"/>
			<TextView
					android:textAppearance="@style/TextAppearance.App.Subtitle"
					android:textStyle="bold"
					android:gravity="center_vertical"
					android:id="@+id/txt_debtor"
					android:focusable="false"
					android:clickable="false"
					android:layout_width="0dp"
					android:layout_height="match_parent"
					android:layout_weight="0.35"/>
		</LinearLayout>
	</LinearLayout>
</androidx.cardview.widget.CardView>
