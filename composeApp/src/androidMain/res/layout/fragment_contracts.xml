<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   android:id="@+id/container" android:padding="16dp"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent">
    <TextView android:textSize="16dp" android:textStyle="bold" android:gravity="center_horizontal"
              android:id="@+id/title" android:layout_width="0dp" android:layout_height="wrap_content"
              android:text="@string/str_approve_text" android:layout_marginVertical="8dp"
              app:layout_constraintLeft_toLeftOf="parent" app:layout_constraintRight_toRightOf="parent"
              app:layout_constraintTop_toTopOf="parent"/>
    <TextView android:id="@+id/explanation" android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_marginLeft="8dp" android:text="@string/str_contracts_explanation"
              android:layout_marginVertical="8dp" app:layout_constraintLeft_toLeftOf="parent"
              app:layout_constraintRight_toRightOf="parent" app:layout_constraintTop_toBottomOf="@+id/title"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rcw" android:layout_width="0dp"
                                               android:layout_height="0dp"
                                               app:layout_constraintBottom_toTopOf="@+id/btnRead"
                                               app:layout_constraintLeft_toLeftOf="parent"
                                               app:layout_constraintRight_toRightOf="parent"
                                               app:layout_constraintTop_toBottomOf="@+id/explanation"
                                               app:layout_constraintVertical_weight="1"/>
    <androidx.appcompat.widget.AppCompatButton android:textColor="@color/white" android:id="@+id/btnRead"
                                               android:background="@color/colorDisabled" android:layout_width="280dp"
                                               android:layout_height="48dp" android:layout_marginTop="8dp"
                                               android:text="@string/str_ok" app:layout_constraintBottom_toBottomOf="parent"
                                               app:layout_constraintLeft_toLeftOf="parent"
                                               app:layout_constraintRight_toRightOf="parent"
                                               style="?android:attr/borderlessButtonStyle"/>
</androidx.constraintlayout.widget.ConstraintLayout>