root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
ij_kotlin_name_count_to_use_star_import = 2147483647

[*.md]
trim_trailing_whitespace = true

[*.java]
max_line_length = 100
continuation_indent_size = 4

