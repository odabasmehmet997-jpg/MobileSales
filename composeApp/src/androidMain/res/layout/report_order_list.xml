<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="match_parent">
    <include layout="@layout/toolbar"/>
    <LinearLayout android:gravity="bottom" android:orientation="horizontal" android:id="@+id/linearFilterDiv"
                  android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:baselineAligned="false" android:layout_weight="1">
        <LinearLayout android:gravity="bottom" android:orientation="vertical" android:layout_width="0dp"
                      android:layout_height="wrap_content" android:layout_weight="1">
            <include android:id="@+id/linearDateLayout" layout="@layout/activity_base_report_wcf"/>
        </LinearLayout>
        <LinearLayout android:layout_gravity="bottom" android:orientation="horizontal" android:layout_width="0dp"
                      android:layout_height="match_parent" android:layout_marginLeft="4dp"
                      android:layout_marginBottom="1dp" android:weightSum="1" android:layout_weight="1"
                      android:layout_marginStart="4dp" style="@style/editCalendar">
            <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="match_parent"
                          android:layout_weight="0.7">
                <FrameLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical"
                             android:padding="2dp" android:layout_width="match_parent"
                             android:layout_height="wrap_content" android:baselineAligned="false"
                             android:layout_weight="1">
                    <androidx.appcompat.widget.AppCompatTextView
                            android:textAppearance="?android:attr/textAppearanceSmall" android:textStyle="bold"
                            android:textColor="#e2e1e1" android:gravity="start" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="S. Statü" android:singleLine="true"
                            android:layout_weight="2"/>
                    <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spStatus"
                                                                android:layout_width="match_parent"
                                                                android:layout_height="wrap_content"/>
                </FrameLayout>
                <FrameLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical"
                             android:padding="2dp" android:layout_width="match_parent"
                             android:layout_height="wrap_content" android:baselineAligned="false"
                             android:layout_weight="2">
                    <androidx.appcompat.widget.AppCompatTextView
                            android:textAppearance="?android:attr/textAppearanceSmall" android:textStyle="bold"
                            android:textColor="#e2e1e1" android:gravity="start" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="@string/str_sales_status"
                            android:singleLine="true" android:layout_weight="2"/>
                    <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spOrderStatus"
                                                                android:layout_width="match_parent"
                                                                android:layout_height="wrap_content"/>
                </FrameLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.3">
                <FrameLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical"
                             android:padding="2dp" android:layout_width="match_parent"
                             android:layout_height="match_parent" android:baselineAligned="false">
                    <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center"
                                                                    android:id="@+id/imgList"
                                                                    android:layout_width="48dp"
                                                                    android:layout_height="48dp"
                                                                    android:src="@android:drawable/ic_search_category_default"
                                                                    android:scaleType="fitCenter"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:layout_marginTop="2dp" android:layout_weight="1">
        <View android:layout_gravity="center_vertical" android:background="#55e2e1e1" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp" android:layout_marginTop="1dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="@color/line_color"
              android:paddingBottom="1dp" android:layout_width="match_parent" android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                      android:id="@+id/linearMaterial2" android:layout_width="match_parent"
                      android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:tag="0" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp" android:text=""
                                                         android:singleLine="true" android:layout_weight="1"
                                                         android:layout_marginEnd="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:tag="0" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_sales_order_state"
                                                         android:singleLine="true" android:layout_weight="3"
                                                         android:layout_marginEnd="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:tag="0" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_sales_status"
                                                         android:singleLine="true" android:layout_weight="3"
                                                         android:layout_marginEnd="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:tag="0" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_date" android:singleLine="true"
                                                         android:layout_weight="2" android:layout_marginEnd="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:tag="0" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_fiche_number"
                                                         android:singleLine="false" android:layout_weight="2"
                                                         android:layout_marginEnd="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:tag="0" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_total" android:singleLine="true"
                                                         android:layout_weight="2" android:layout_marginEnd="4dp"/>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="100">
        <ListView android:id="@+id/lvReportOrder" android:scrollbars="none" android:layout_width="match_parent"
                  android:layout_height="match_parent" android:divider="@null"/>
        <LinearLayout android:gravity="bottom|center_vertical|center_horizontal|center"
                      android:layout_gravity="bottom|center_vertical|center_horizontal|center"
                      android:id="@+id/linearProgress" android:background="#99000000"
                      android:layout_width="match_parent" android:layout_height="match_parent">
            <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>