<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="match_parent">
    <com.proje.mobilesales.core.widget.AppBarSwipeRefreshLayout android:id="@+id/swipe_layout"
                                                                android:layout_width="match_parent"
                                                                android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView android:scrollbarStyle="insideOverlay" android:scrollbars="vertical"
                                               android:layout_width="match_parent" android:layout_height="match_parent">
            <RelativeLayout android:orientation="vertical" android:id="@+id/content_frame"
                            android:layout_width="match_parent" android:layout_height="match_parent">
                <LinearLayout android:orientation="vertical" android:id="@+id/ln_customerBalanceTable"
                              android:layout_width="match_parent" android:layout_height="match_parent">
                    <TextView android:gravity="center_horizontal" android:padding="@dimen/activity_quad_vertical_margin"
                              android:layout_width="match_parent" android:layout_height="wrap_content"
                              android:text="@string/str_customer_balance_title"
                              style="@style/textTitleStyle"/>
                    <LinearLayout android:orientation="horizontal" android:id="@+id/ln_customerTotalRow"
                                  android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:weightSum="1">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                  android:text="@string/str_customer_total_title" android:layout_weight="0.5"
                                  style="@style/textCustomerGeneralStyle"/>
                        <TextView android:gravity="end" android:id="@+id/txt_customerTotal" android:layout_width="0dp"
                                  android:layout_height="wrap_content" android:layout_weight="0.5"
                                  style="@style/textCustomerGeneralStyle"/>
                    </LinearLayout>
                    <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                          android:layout_height="1dp"
                          android:layout_marginStart="@dimen/activity_vertical_margin"/>
                    <LinearLayout android:orientation="horizontal" android:id="@+id/ln_customerInvoiceRow"
                                  android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:weightSum="1">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                  android:text="@string/str_customer_summary_invoice_title" android:layout_weight="0.5"
                                  style="@style/textCustomerGeneralStyle"/>
                        <TextView android:gravity="end" android:id="@+id/txt_customerInvoiceTotal"
                                  android:layout_width="0dp" android:layout_height="wrap_content"
                                  android:layout_weight="0.5" style="@style/textCustomerGeneralStyle"/>
                    </LinearLayout>
                    <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                          android:layout_height="1dp"
                          android:layout_marginStart="@dimen/activity_vertical_margin"/>
                    <LinearLayout android:orientation="horizontal" android:id="@+id/ln_customerOrderRow"
                                  android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:weightSum="1">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                  android:text="@string/str_customer_summary_order_title" android:layout_weight="0.5"
                                  style="@style/textCustomerGeneralStyle"/>
                        <TextView android:gravity="end" android:id="@+id/txt_customerOrderTotal"
                                  android:layout_width="0dp" android:layout_height="wrap_content"
                                  android:layout_weight="0.5" style="@style/textCustomerGeneralStyle"/>
                    </LinearLayout>
                    <View android:background="@color/colorDivider2" android:layout_width="match_parent"
                          android:layout_height="2dp"
                          android:layout_marginStart="@dimen/activity_vertical_margin"/>
                    <LinearLayout android:orientation="horizontal" android:id="@+id/ln_customerBalanceTotalRow"
                                  android:layout_width="match_parent" android:layout_height="wrap_content"
                                  android:weightSum="1">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                  android:text="@string/str_total_quantity" android:layout_weight="0.5"
                                  style="@style/textCustomerGeneralStyle"/>
                        <TextView android:textStyle="bold" android:gravity="end"
                                  android:id="@+id/txt_customerBalanceTotal" android:layout_width="0dp"
                                  android:layout_height="wrap_content" android:layout_weight="0.5"
                                  style="@style/textCustomerGeneralStyle"/>
                    </LinearLayout>
                </LinearLayout>
                <RelativeLayout android:id="@+id/rlt_extractCurrencyBalance" android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_below="@+id/ln_customerBalanceTable">
                    <View android:id="@+id/rlt_extractCurrencyBalanceView" android:background="@color/colorDivider2"
                          android:layout_width="match_parent" android:layout_height="1dp"
                          android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <TextView android:gravity="center_horizontal" android:id="@+id/txt_extractCurrencyTitle"
                              android:padding="@dimen/activity_quad_vertical_margin" android:layout_width="match_parent"
                              android:layout_height="wrap_content" android:text="@string/str_other_currency_sum"
                              android:layout_below="@+id/rlt_extractCurrencyBalanceView"
                              android:layout_centerHorizontal="true" style="@style/textTitleStyle"/>
                    <RelativeLayout android:id="@+id/rlt_currencyContent" android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@+id/txt_extractCurrencyTitle"/>
                </RelativeLayout>
                <RelativeLayout android:id="@+id/rlt_customerTop10Product" android:visibility="gone"
                                android:layout_width="match_parent" android:layout_height="match_parent"
                                android:layout_below="@+id/rlt_extractCurrencyBalance">
                    <View android:id="@+id/rlt_customerTop10ProductView" android:background="@color/colorDivider2"
                          android:layout_width="match_parent" android:layout_height="1dp"
                          android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <TextView android:gravity="center_horizontal" android:id="@+id/txt_customerTop10Product"
                              android:padding="@dimen/activity_quad_vertical_margin" android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:text="@string/str_customer_summary_top_ten_product"
                              android:layout_below="@+id/rlt_customerTop10ProductView"
                              android:layout_centerHorizontal="true" style="@style/textTitleStyle"/>
                    <FrameLayout android:id="@+id/chartFrame" android:layout_width="match_parent"
                                 android:layout_height="1000dp" android:layout_below="@+id/txt_customerTop10Product"/>
                </RelativeLayout>
                <RelativeLayout android:id="@+id/rlt_customerSales" android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_below="@+id/rlt_customerTop10Product">
                    <View android:id="@+id/rlt_customerSalesView" android:background="@color/colorDivider2"
                          android:layout_width="match_parent" android:layout_height="1dp"
                          android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                    <androidx.appcompat.widget.AppCompatCheckedTextView android:gravity="center_horizontal"
                                                                        android:id="@+id/txt_customerSalesTitle"
                                                                        android:padding="@dimen/activity_quad_vertical_margin"
                                                                        android:layout_width="match_parent"
                                                                        android:layout_height="wrap_content"
                                                                        android:checked="true"
                                                                        android:text="@string/str_customer_summary_weekly_sales"
                                                                        android:layout_below="@+id/rlt_customerSalesView"
                                                                        android:layout_centerHorizontal="true"
                                                                        style="@style/textTitleStyle"/>
                    <FrameLayout android:id="@+id/chartFrame2" android:layout_width="match_parent"
                                 android:layout_height="500dp" android:layout_below="@+id/txt_customerSalesTitle"/>
                </RelativeLayout>
            </RelativeLayout>
        </androidx.core.widget.NestedScrollView>
    </com.proje.mobilesales.core.widget.AppBarSwipeRefreshLayout>
    <include android:id="@+id/empty" layout="@layout/empty_list"/>
</RelativeLayout>