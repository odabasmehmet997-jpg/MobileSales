<?xml version='1.0' encoding='utf-8'?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="fill_parent" android:layout_height="fill_parent">
    <include layout="@layout/toolbar"/>
    <LinearLayout android:gravity="bottom"
                  android:orientation="horizontal"
                  android:id="@id/linearFilterDiv"
                  android:padding="8.0dp"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:baselineAligned="false"
                  android:layout_weight="1.0">
        <LinearLayout android:gravity="bottom"
                      android:orientation="vertical"
                      android:layout_width="0.0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1.0">
            <include android:id="@id/linearDateLayout"
                     layout="@layout/activity_base_report_wcf"/>
        </LinearLayout>
        <LinearLayout android:layout_gravity="bottom"
                      android:layout_width="0.0dp"
                      android:layout_height="wrap_content"
                      android:layout_marginLeft="4.0dp"
                      android:layout_marginBottom="1.0dp"
                      android:layout_weight="1.25"
                      android:layout_marginStart="4.0dp">
            <FrameLayout android:gravity="bottom"
                         android:layout_gravity="bottom"
                         android:orientation="vertical"
                         android:padding="2.0dp"
                         android:layout_width="0.0dp"
                         android:layout_height="wrap_content"
                         android:baselineAligned="false"
                         android:layout_weight="1.0">
                <androidx.appcompat.widget.AppCompatSpinner android:id="@id/spUser"
                                                            android:layout_width="fill_parent"
                                                            android:layout_height="wrap_content"
                                                            android:minHeight="48dp"/>
                <LinearLayout android:gravity="center"
                              android:layout_gravity="center"
                              android:id="@id/linearProgressSpin"
                              android:layout_width="fill_parent"
                              android:layout_height="fill_parent">
                    <ProgressBar android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:id="@id/imgList"
                                                            android:layout_width="48.0dp"
                                                            android:layout_height="48.0dp"
                                                            android:src="@android:drawable/ic_search_category_default"
                                                            android:scaleType="fitCenter"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical"
                  android:background="@android:color/transparent"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="2.0dp"
                  android:layout_weight="1.0">
        <View android:layout_gravity="center_vertical"
              android:background="#55e2e1e1"
              android:paddingBottom="1.0dp"
              android:layout_width="fill_parent"
              android:layout_height="0.1sp"
              android:layout_marginTop="1.0dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical"
                  android:background="@android:color/transparent"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical"
              android:background="@color/line_color"
              android:paddingBottom="1.0dp"
              android:layout_width="fill_parent"
              android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical"
                      android:orientation="horizontal"
                      android:id="@id/linearMaterial2"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent">
            <androidx.appcompat.widget.AppCompatCheckBox android:id="@id/chkBoxReportAvg"
                                                         android:visibility="invisible"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4.0dp"
                                                         android:layout_weight="1.5"
                                                         android:layout_marginEnd="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/txtViewTarih"
                                                         android:tag="0"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4.0dp"
                                                         android:text="@string/str_date"
                                                         android:layout_weight="3.3"
                                                         android:layout_marginEnd="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/txtViewFisNo"
                                                         android:tag="1"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4.0dp"
                                                         android:layout_marginRight="4.0dp"
                                                         android:text="@string/str_fiche_number"
                                                         android:singleLine="true"
                                                         android:layout_weight="4.0"
                                                         android:layout_marginStart="4.0dp"
                                                         android:layout_marginEnd="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/txtViewTutar"
                                                         android:tag="2"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4.0dp"
                                                         android:layout_marginRight="4.0dp"
                                                         android:text="@string/str_total"
                                                         android:singleLine="true"
                                                         android:layout_weight="2.0"
                                                         android:layout_marginStart="4.0dp"
                                                         android:layout_marginEnd="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/txtIndirimTutari"
                                                         android:tag="3"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4.0dp"
                                                         android:layout_marginRight="4.0dp"
                                                         android:text="@string/str_discount_price"
                                                         android:singleLine="true"
                                                         android:layout_weight="2.0"
                                                         android:layout_marginStart="4.0dp"
                                                         android:layout_marginEnd="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/txtNetTutar"
                                                         android:tag="4"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4.0dp"
                                                         android:text="@string/str_net_total"
                                                         android:singleLine="true"
                                                         android:layout_weight="2.0"
                                                         android:layout_marginStart="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/txtAciklama"
                                                         android:tag="4"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4.0dp"
                                                         android:text="@string/str_explanation"
                                                         android:singleLine="true"
                                                         android:layout_weight="2.0"
                                                         android:layout_marginStart="4.0dp"/>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout android:layout_width="fill_parent"
                 android:layout_height="0.0dp"
                 android:layout_weight="100.0">
        <ListView android:id="@id/lvReportOrder"
                  android:scrollbars="none"
                  android:layout_width="fill_parent"
                  android:layout_height="fill_parent"
                  android:divider="@null"/>
        <LinearLayout android:gravity="bottom|center"
                      android:layout_gravity="bottom|center"
                      android:id="@id/linearProgress"
                      android:background="#99000000"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent">
            <ProgressBar android:layout_width="wrap_content"
                         android:layout_height="wrap_content"/>
        </LinearLayout>
    </FrameLayout>
    <LinearLayout android:gravity="center_vertical"
                  android:orientation="vertical"
                  android:background="@android:color/transparent"
                  android:layout_width="fill_parent"
                  android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical"
              android:background="#55e2e1e1"
              android:paddingBottom="1.0dp"
              android:layout_width="fill_parent"
              android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical"
                      android:orientation="horizontal"
                      android:layout_width="fill_parent"
                      android:layout_height="fill_parent">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold"
                                                         android:id="@id/txtViewCalDate"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginRight="4.0dp"
                                                         android:text="Tarih:"
                                                         android:singleLine="false"
                                                         android:layout_weight="5.0"
                                                         android:layout_marginEnd="4.0dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold"
                                                         android:id="@id/txtViewCalDay"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="Gün:0"
                                                         android:singleLine="false"
                                                         android:layout_weight="5.0"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold"
                                                         android:id="@id/txtViewCalTotal"
                                                         android:layout_width="0.0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="Toplam:0"
                                                         android:singleLine="false"
                                                         android:layout_weight="5.0"/>
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:id="@+id/btnCalAvgInv"
                                                            android:layout_width="36.0dp"
                                                            android:layout_height="36.0dp"
                                                            android:src="@android:drawable/ic_search_category_default"
                                                            android:scaleType="fitCenter"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>