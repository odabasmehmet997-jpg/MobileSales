<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
                                   android:layout_width="match_parent" android:layout_height="wrap_content"
                                   style="@style/AppCardView">
    <LinearLayout android:orientation="horizontal" android:id="@+id/ln_customerGeneralProp"
                  android:layout_width="match_parent" android:layout_height="match_parent" android:weightSum="1">
        <TextView android:id="@+id/txt_customerGeneralPropKey" android:layout_weight="0.45" android:textAllCaps="true"
                  style="@style/textCustomerGeneralStyle"/>
        <TextView android:gravity="end" android:id="@+id/txt_customerGeneralPropValue" android:layout_weight="0.55"
                  style="@style/textCustomerGeneralValueStyle"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>