<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="match_parent">
    <include layout="@layout/toolbar"/>
    <LinearLayout android:orientation="horizontal" android:id="@+id/linearFilterDiv" android:padding="8dp"
                  android:visibility="visible" android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:baselineAligned="false" android:layout_weight="1">
        <LinearLayout android:gravity="bottom" android:orientation="vertical" android:layout_width="0dp"
                      android:layout_height="wrap_content" android:layout_weight="1">
            <include android:id="@+id/linearDateLayout" layout="@layout/activity_base_report_wcf"/>
        </LinearLayout>
        <LinearLayout android:layout_gravity="top" android:id="@+id/ln_debit_filter" android:visibility="visible"
                      android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="4dp"
                      android:layout_marginBottom="1dp" android:layout_weight="1.25" android:layout_marginStart="4dp"
                      style="@style/editCalendar">
            <FrameLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical"
                         android:id="@+id/frm_debit_filter" android:padding="2dp" android:layout_width="0dp"
                         android:layout_height="wrap_content" android:baselineAligned="false" android:layout_weight="1">
                <androidx.appcompat.widget.AppCompatSpinner android:id="@+id/spClose"
                                                            android:layout_width="match_parent"
                                                            android:layout_height="wrap_content"/>
            </FrameLayout>
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:id="@+id/imgList" android:layout_width="48dp"
                                                            android:layout_height="48dp"
                                                            android:src="@android:drawable/ic_search_category_default"
                                                            android:scaleType="fitCenter"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="@color/subMenu2" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                      android:id="@+id/linearMaterial2" android:layout_width="match_parent"
                      android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_fiche_type" android:singleLine="true"
                                                         android:layout_weight="3" style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:id="@+id/appCompatTextView"
                                                         android:text="@string/str_due_date" android:singleLine="true"
                                                         android:layout_weight="2" style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_transaction_date"
                                                         android:singleLine="true" android:layout_weight="2"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_due_date_day"
                                                         android:singleLine="true" android:layout_weight="2"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_document_number"
                                                         android:singleLine="true" android:layout_weight="2"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_fiche_number"
                                                         android:singleLine="true" android:layout_weight="3"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_total" android:singleLine="true"
                                                         android:layout_weight="3" style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:text="@string/str_balance" android:singleLine="true"
                                                         android:layout_weight="3" style="@style/ReportTitleTextView"
                                                         android:textColor="#1B5E20"/>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="100">
        <ListView android:id="@+id/lvReportOrder" android:scrollbars="none" android:layout_width="match_parent"
                  android:layout_height="match_parent" android:divider="@null"/>
        <LinearLayout android:gravity="bottom|center_vertical|center_horizontal|center"
                      android:layout_gravity="bottom|center_vertical|center_horizontal|center"
                      android:id="@+id/linearProgress" android:background="#99000000"
                      android:layout_width="match_parent" android:layout_height="match_parent">
            <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </FrameLayout>
    <LinearLayout android:gravity="center_vertical" android:orientation="vertical"
                  android:background="@android:color/transparent" android:layout_width="match_parent"
                  android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="@color/subMenu2" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                      android:layout_width="match_parent" android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:gravity="start"
                                                         android:id="@+id/txtViewCalDate" android:paddingLeft="2dp"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:text="Tarih:" android:singleLine="false"
                                                         android:layout_weight="5" android:paddingStart="2dp"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#546E7A"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:gravity="start"
                                                         android:id="@+id/txtViewCalDay" android:paddingLeft="2dp"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:text="Gün:0" android:singleLine="false"
                                                         android:layout_weight="5" android:paddingStart="2dp"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#546E7A"/>
            <View android:background="@color/white" android:layout_width="1dp" android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:gravity="start"
                                                         android:id="@+id/txtViewCalTotal" android:paddingLeft="2dp"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:text="Toplam:0" android:singleLine="false"
                                                         android:layout_weight="5" android:paddingStart="2dp"
                                                         style="@style/ReportTitleTextView"
                                                         android:textColor="#546E7A"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>