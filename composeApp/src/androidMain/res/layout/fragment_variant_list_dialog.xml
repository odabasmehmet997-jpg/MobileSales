<?xml version='1.0' encoding='utf-8'?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:tag="layout/fragment_variant_list_dialog_0"
        android:focusableInTouchMode="true"
        android:descendantFocusability="beforeDescendants"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
  <androidx.appcompat.widget.AppCompatImageButton
    android:gravity="center"
    android:id="@+id/btnCancel"
    android:background="@null"
    android:padding="12.0dp"
    android:layout_width="45.0dp"
    android:layout_height="45.0dp"
    android:src="@drawable/ic_baseline_arrow_back_24"
    android:scaleType="fitCenter"
    android:tint="@color/mtrl_choice_chip_text_color"
    android:layout_weight="1.0"
    android:contentDescription="@string/str_cancel"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
            android:ellipsize="end"
            android:id="@+id/tvProduct"
            android:paddingTop="8.0dp"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:maxHeight="45.0dp"
            android:text="@string/str_variant"
            android:singleLine="true"
            android:textAlignment="center"
            android:layout_marginEnd="45.0dp"
            app:layout_constraintEnd_toStartOf="@+id/btnDone"
            app:layout_constraintStart_toEndOf="@+id/btnCancel"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/textTitleStyle"/>
    <androidx.appcompat.widget.AppCompatImageButton
            android:gravity="center"
            android:id="@+id/btnSelectAll"
            android:tag="binding_1"
            android:background="@null"
            android:padding="12.0dp"
            android:layout_width="48.0dp"
            android:layout_height="48.0dp"
            android:src="@drawable/ic_baseline_check_box_outline_blank_24"
            android:scaleType="fitCenter"
            android:tint="@color/colorAccent"
            android:layout_weight="1.0"
            android:contentDescription="@string/menu_select_all"
            app:layout_constraintEnd_toStartOf="@+id/btnDone"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="DuplicateClickableBoundsCheck"/>
  <androidx.appcompat.widget.AppCompatImageButton
    android:gravity="center"
    android:id="@+id/btnUnSelectAll"
    android:tag="binding_2"
    android:background="@null"
    android:padding="12.0dp"
    android:layout_width="48.0dp"
    android:layout_height="48.0dp"
    android:src="@drawable/ic_baseline_check_box_24"
    android:scaleType="fitCenter"
    android:tint="@color/mtrl_choice_chip_text_color"
    android:layout_weight="1.0"
    android:contentDescription="@string/str_remove_all"
    app:layout_constraintEnd_toStartOf="@+id/btnDone"
    app:layout_constraintTop_toTopOf="parent"/>
  <androidx.appcompat.widget.AppCompatImageButton
    android:gravity="center"
    android:id="@+id/btnDone"
    android:background="@null"
    android:padding="12.0dp"
    android:layout_width="45.0dp"
    android:layout_height="45.0dp"
    android:src="@drawable/ic_baseline_done_all_24"
    android:scaleType="fitCenter"
    android:tint="@color/orange300"
    android:text="Tamam"
    android:layout_weight="1.0"
    android:contentDescription="@string/str_okey"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/edtSearch"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:minHeight="48.0dp"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:contentDescription="@string/str_variant"
            android:layout_marginStart="10.0dp"
            android:layout_marginEnd="10.0dp"
            app:layout_constraintEnd_toStartOf="@+id/imgBtnSearch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnCancel"
            tools:ignore="EditableContentDescCheck"/>
    <androidx.appcompat.widget.AppCompatTextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:gravity="center_vertical"
            android:layout_gravity="center|end"
            android:id="@+id/tvCheckedCount"
            android:tag="binding_3"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="45.0dp"
            app:layout_constraintEnd_toStartOf="@+id/imgBtnSearch"
            app:layout_constraintTop_toBottomOf="@+id/btnCancel"/>
    <androidx.appcompat.widget.AppCompatImageButton
            android:gravity="center"
            android:id="@+id/imgBtnClearSearch"
            android:background="@null"
            android:padding="12.0dp"
            android:layout_width="48.0dp"
            android:layout_height="48.0dp"
            android:src="@drawable/ic_baseline_search_off_24"
            android:scaleType="fitCenter"
            android:tint="@color/grey600"
            android:layout_weight="1.0"
            android:contentDescription="@string/str_clear"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnCancel"/>
    <androidx.appcompat.widget.AppCompatImageButton android:gravity="center"
                                                    android:id="@+id/imgBtnSearch"
                                                    android:background="@null"
                                                    android:padding="12.0dp"
                                                    android:layout_width="48.0dp"
                                                    android:layout_height="48.0dp"
                                                    android:src="@drawable/ic_baseline_search_24"
                                                    android:scaleType="fitCenter"
                                                    android:tint="@color/grey600"
                                                    android:layout_weight="1.0"
                                                    android:contentDescription="@string/str_search"
                                                    app:layout_constraintEnd_toStartOf="@+id/imgBtnClearSearch"
                                                    app:layout_constraintTop_toBottomOf="@+id/btnCancel"/>
    <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceMedium"
                                                 android:id="@+id/tvSerialNo"
                                                 android:layout_width="0.0dp"
                                                 android:layout_height="wrap_content"
                                                 android:maxHeight="45.0dp"
                                                 android:text="@string/str_variant"
                                                 android:layout_marginStart="10.0dp"
                                                 android:layout_marginEnd="10.0dp"
                                                 app:layout_constraintEnd_toStartOf="@+id/tvCheckedCount"
                                                 app:layout_constraintStart_toStartOf="parent"
                                                 app:layout_constraintTop_toBottomOf="@+id/edtSearch"/>
    <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceMedium"
                                                 android:id="@+id/tvUserAmount"
                                                 android:layout_width="0.0dp"
                                                 android:layout_height="wrap_content"
                                                 android:layout_marginBottom="8.0dp"
                                                 android:maxHeight="45.0dp"
                                                 android:text="@string/str_quantity"
                                                 android:singleLine="true"
                                                 android:layout_marginStart="4.0dp"
                                                 android:layout_marginEnd="4.0dp"
                                                 app:layout_constraintEnd_toEndOf="parent"
                                                 app:layout_constraintStart_toEndOf="@+id/tvSerialNo"
                                                 app:layout_constraintTop_toBottomOf="@+id/tvCheckedCount"/>
    <View android:id="@+id/seperator"
          android:background="#33999999"
          android:layout_width="fill_parent"
          android:layout_height="2.0dp"
          android:layout_marginTop="8.0dp"
          android:layout_marginBottom="8.0dp"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toBottomOf="@+id/tvUserAmount"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/list"
                                               android:paddingBottom="@dimen/list_item_spacing_half"
                                               android:clipToPadding="false"
                                               android:layout_width="fill_parent"
                                               android:layout_height="0.0dp"
                                               app:layout_constraintBottom_toBottomOf="parent"
                                               app:layout_constraintEnd_toEndOf="parent"
                                               app:layout_constraintStart_toStartOf="parent"
                                               app:layout_constraintTop_toBottomOf="@+id/seperator"/>
    <include android:id="@+id/llProgressBar"
             android:visibility="gone"
             layout="@layout/loading_item"/>
</androidx.constraintlayout.widget.ConstraintLayout>
