<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="match_parent">
    <TextView android:textColor="#fff" android:id="@+id/txt_title_device" android:background="#666"
              android:paddingLeft="5dp" android:visibility="gone" android:layout_width="match_parent"
              android:layout_height="wrap_content" android:text="@string/str_title_devices" android:paddingStart="5dp"/>
    <ListView android:id="@+id/lst_device" android:layout_width="match_parent" android:layout_height="0dp"
              android:stackFromBottom="true" android:layout_weight="1"/>
    <Button android:id="@+id/btn_scan" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/str_scan_devices" android:drawableLeft="@drawable/ic_magnify_grey600_24dp"
            android:drawableStart="@drawable/ic_magnify_grey600_24dp"/>
</LinearLayout>