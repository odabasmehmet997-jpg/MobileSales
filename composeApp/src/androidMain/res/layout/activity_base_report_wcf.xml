<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent"
                  android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:id="@+id/linearDate1" android:focusable="false"
                      android:focusableInTouchMode="false" android:clickable="true" android:layout_width="match_parent"
                      android:layout_height="wrap_content" android:layout_margin="1dp" style="@style/editCalendar">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceMedium"
                                                         android:id="@+id/tvDate1" android:focusable="false"
                                                         android:clickable="false" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4dp" android:singleLine="true"
                                                         android:layout_weight="100" android:layout_marginStart="4dp"/>
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:background="@android:color/transparent"
                                                            android:focusable="false" android:clickable="false"
                                                            android:layout_width="wrap_content"
                                                            android:layout_height="wrap_content"
                                                            android:src="@android:drawable/ic_menu_my_calendar"
                                                            android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:id="@+id/linearDate2" android:focusable="false"
                      android:focusableInTouchMode="false" android:clickable="true" android:layout_width="match_parent"
                      android:layout_height="wrap_content" android:layout_margin="1dp" style="@style/editCalendar">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceMedium"
                                                         android:id="@+id/tvDate2" android:focusable="false"
                                                         android:clickable="false" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4dp" android:singleLine="true"
                                                         android:layout_weight="100" android:layout_marginStart="4dp"/>
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:background="@android:color/transparent"
                                                            android:focusable="false" android:clickable="false"
                                                            android:layout_width="wrap_content"
                                                            android:layout_height="wrap_content"
                                                            android:src="@android:drawable/ic_menu_my_calendar"
                                                            android:layout_weight="1"/>
        </LinearLayout>
        <View android:layout_gravity="center_vertical" android:background="#55e2e1e1" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp" android:layout_marginTop="1dp"/>
    </LinearLayout>
</merge>