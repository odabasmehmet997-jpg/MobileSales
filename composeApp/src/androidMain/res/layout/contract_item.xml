                  android:layout_height="wrap_content">
        <CheckBox android:id="@+id/chk_contract" android:layout_width="wrap_content"
                  android:layout_height="match_parent"/>
        <TextView android:gravity="center_vertical" android:id="@+id/txt_contract" android:layout_width="wrap_content"
                  android:layout_height="match_parent" android:text="Aydınlatma metnini okudum, onaylıyorum"/>
    </LinearLayout>
</LinearLayout>