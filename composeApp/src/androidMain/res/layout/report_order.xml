<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical"
              android:layout_width="match_parent" android:layout_height="match_parent">
    <include layout="@layout/toolbar"/>
    <LinearLayout android:gravity="bottom" android:orientation="horizontal" android:id="@+id/linearFilterDiv"
                  android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:baselineAligned="false" android:layout_weight="1">
        <LinearLayout android:gravity="bottom" android:orientation="vertical" android:layout_width="0dp"
                      android:layout_height="wrap_content" android:layout_weight="1">
            <include android:id="@+id/linearDateLayout" layout="@layout/activity_base_report_wcf"/>
        </LinearLayout>
        <LinearLayout android:layout_gravity="bottom" android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_marginLeft="4dp" android:layout_marginBottom="1dp" android:layout_weight="1.25"
                      android:layout_marginStart="4dp" style="@style/editCalendar">
            <FrameLayout android:gravity="bottom" android:layout_gravity="bottom" android:orientation="vertical"
                         android:padding="2dp" android:layout_width="0dp" android:layout_height="wrap_content"
                         android:baselineAligned="false" android:layout_weight="1">
                <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:gravity="center"
                          android:id="@+id/spUser" android:layout_width="match_parent"
                          android:layout_height="match_parent"
                          app:drawableEndCompat="@drawable/ic_chevron_down_black_24dp"/>
                <LinearLayout android:gravity="center" android:layout_gravity="center"
                              android:id="@+id/linearProgressSpin" android:layout_width="match_parent"
                              android:layout_height="match_parent">
                    <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>
            <androidx.appcompat.widget.AppCompatImageButton android:layout_gravity="center_vertical"
                                                            android:id="@+id/imgList" android:layout_width="48dp"
                                                            android:layout_height="48dp"
                                                            android:src="@android:drawable/ic_search_category_default"
                                                            android:scaleType="fitCenter"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:layout_marginTop="2dp" android:layout_weight="1">
        <View android:layout_gravity="center_vertical" android:background="#55e2e1e1" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp" android:layout_marginTop="1dp"/>
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:background="@android:color/transparent"
                  android:layout_width="match_parent" android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="@color/line_color"
              android:paddingBottom="1dp" android:layout_width="match_parent" android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                      android:id="@+id/linearMaterial2" android:layout_width="match_parent"
                      android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/tvFicheNo" android:tag="0"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_fiche_number"
                                                         android:layout_weight="4" android:layout_marginEnd="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:id="@+id/tvCode" android:tag="1"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:layout_marginLeft="4dp"
                                                         android:layout_marginRight="4dp"
                                                         android:text="@string/str_code" android:singleLine="true"
                                                         android:layout_weight="1.5" android:layout_marginStart="4dp"
                                                         android:layout_marginEnd="4dp"/>
            <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:id="@+id/tvDefinition_"
                      android:tag="2" android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
                      android:text="@string/str_definition" android:singleLine="true" android:layout_weight="3"
                      android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
            <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:id="@+id/tvOrderState"
                      android:tag="2" android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
                      android:text="@string/str_sales_order_state" android:singleLine="true" android:layout_weight="2"
                      android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
            <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:gravity="right"
                      android:id="@+id/tvGrossTotal" android:tag="3" android:layout_width="0dp"
                      android:layout_height="wrap_content" android:layout_marginLeft="4dp"
                      android:layout_marginRight="4dp" android:text="@string/str_total" android:singleLine="true"
                      android:layout_weight="2" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
            <TextView android:textAppearance="?android:attr/textAppearanceSmall" android:gravity="right"
                      android:id="@+id/tvNetTotal" android:tag="4" android:layout_width="0dp"
                      android:layout_height="wrap_content" android:layout_marginLeft="4dp"
                      android:text="@string/str_net_total" android:layout_weight="2" android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="100">
        <ListView android:id="@+id/lvReportOrder" android:scrollbars="none" android:layout_width="match_parent"
                  android:layout_height="match_parent" android:divider="@null"/>
        <LinearLayout android:gravity="bottom|center_vertical|center_horizontal|center"
                      android:layout_gravity="bottom|center_vertical|center_horizontal|center"
                      android:id="@+id/linearProgress" android:layout_width="match_parent"
                      android:layout_height="match_parent">
            <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </FrameLayout>
    <LinearLayout android:gravity="center_vertical" android:orientation="vertical"
                  android:background="@android:color/transparent" android:layout_width="match_parent"
                  android:layout_height="wrap_content">
        <View android:layout_gravity="center_vertical" android:background="#55e2e1e1" android:paddingBottom="1dp"
              android:layout_width="match_parent" android:layout_height="0.1sp"/>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal"
                      android:layout_width="match_parent" android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_displayed" android:singleLine="true"
                                                         android:layout_weight="4"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:id="@+id/tvShowing"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:text="@string/str_tmp_0" android:layout_weight="2"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:gravity="end"
                                                         android:layout_width="0dp" android:layout_height="wrap_content"
                                                         android:text="@string/str_total_quantity"
                                                         android:singleLine="true" android:layout_weight="2"/>
            <androidx.appcompat.widget.AppCompatTextView android:textAppearance="?android:attr/textAppearanceSmall"
                                                         android:textStyle="bold" android:gravity="end"
                                                         android:id="@+id/tvTotal" android:layout_width="0dp"
                                                         android:layout_height="wrap_content"
                                                         android:text="@string/str_tmp_0_float"
                                                         android:layout_weight="4"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
