<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
       android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:id="@+id/ln_fiche_property" android:layout_width="match_parent"
                  android:layout_height="wrap_content" android:weightSum="1">
        <TextView android:layout_gravity="left|center_vertical|center_horizontal|center|start"
                  android:id="@+id/txt_fiche_property_title" android:layout_width="0dp"
                  android:layout_height="match_parent" android:layout_weight="0.45" android:textAllCaps="true"
                  style="@style/textCustomerSalesHeaderStyle"/>
        <EditText android:textStyle="bold" android:id="@+id/edt_fiche_property_edit" android:scrollbars="vertical"
                  android:layout_width="0dp" android:layout_height="match_parent" android:maxLines="10"
                  android:lines="10" android:minLines="1" android:singleLine="false" android:layout_weight="0.55"
                  android:inputType="textMultiLine" android:imeOptions="actionPrevious"
                  style="@style/textCustomerSalesHeaderStyle"/>
    </LinearLayout>
    <View android:background="@color/colorDivider2" android:layout_width="match_parent" android:layout_height="1dp"/>
</merge>