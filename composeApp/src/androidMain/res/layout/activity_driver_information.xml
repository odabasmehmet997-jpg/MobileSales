<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical"
              android:focusable="true" android:focusableInTouchMode="true" android:layout_width="match_parent"
              android:layout_height="match_parent">
    <include layout="@layout/toolbar"/>
    <androidx.core.widget.NestedScrollView android:scrollbarStyle="outsideOverlay" android:scrollbars="vertical"
                                           android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:id="@+id/driverInfoLayout"
                      android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:textStyle="bold" android:gravity="center_horizontal" android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/activity_half_vertical_margin"
                      android:layout_marginBottom="@dimen/activity_half_vertical_margin"
                      android:text="@string/str_firstDriverInfo"
                      style="@style/textTitleStyle"/>
            <include android:id="@+id/driver1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                     layout="@layout/driver_information_item"/>
            <TextView android:textStyle="bold" android:gravity="center_horizontal" android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/activity_half_vertical_margin"
                      android:layout_marginBottom="@dimen/activity_half_vertical_margin"
                      android:text="@string/str_secondDriverInfo"
                      style="@style/textTitleStyle"/>
            <include android:id="@+id/driver2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                     layout="@layout/driver_information_item"/>
            <TextView android:textStyle="bold" android:gravity="center_horizontal" android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="@dimen/activity_half_vertical_margin"
                      android:layout_marginBottom="@dimen/activity_half_vertical_margin"
                      android:text="@string/str_thirdDriverInfo"
                      style="@style/textTitleStyle"/>
            <include android:id="@+id/driver3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                     layout="@layout/driver_information_item"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
